{
  "name": "trisilar-task-hub",
  "version": "1.0.0",
  "description": "Trisilar Task Hub — unified Trello & Google Calendar dashboard",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "smoke": "node scripts/smoke-test.js",
    "verify": "node scripts/verify-frontend.js",
    "verify:paperclip-contract": "node scripts/verify-paperclip-contract.js",
    "verify:paperclip-connection": "node scripts/verify-paperclip-connection.js",
    "verify:paperclip-docs": "node scripts/verify-paperclip-docs.js",
    "verify:paperclip-webhook": "node scripts/verify-paperclip-webhook.js",
    "verify:paperclip-production-readiness": "node scripts/verify-paperclip-production-readiness.js",
    "verify:paperclip-cleanup": "node scripts/verify-paperclip-cleanup.js",
    "verify:paperclip-operations": "node scripts/verify-paperclip-operations.js",
    "verify:paperclip-mock": "node scripts/verify-paperclip-mock.js",
    "verify:sqlite-canary": "node scripts/verify-sqlite-canary.js",
    "verify:contracts": "node --test tests/app-contracts.test.js",
    "migrate:sqlite": "node scripts/migrate-json-state-to-sqlite.js import",
    "migrate:sqlite:export": "node scripts/migrate-json-state-to-sqlite.js export",
    "verify:rux-trello": "node scripts/verify-rux-trello-connection-ux.js",
    "verify:rux-ai-trace": "node scripts/verify-rux-ai-trace-clarity.js",
    "verify:rux-decision-flow": "node scripts/verify-rux-today-tasks-decision-flow.js",
    "verify:rux-browser-regression": "node scripts/verify-rux-browser-regression.js",
    "check:all": "node scripts/verify-frontend.js && npm run smoke",
    "test": "node --test tests/*.test.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@google/generative-ai": "^0.24.1",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "googleapis": "^171.4.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
